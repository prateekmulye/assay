# LLM backbone — Ollama Cloud (OpenAI-compatible /v1)
OLLAMA_API_KEY=your-ollama-cloud-key-here
LLM_BASE_URL=https://ollama.com/v1

# Web research
FIRECRAWL_API_KEY=your-firecrawl-key-here

# Model tiers (override models.yaml if set)
QUICK_MODEL=gpt-oss:20b
DEEP_MODEL=gpt-oss:120b

# Debate
RESEARCH_DEBATE_ROUNDS=1
RISK_DEBATE_ROUNDS=1
DEBATE_MODE=on

# Memory (verdict cache lives in the warehouse; embeddings stay local)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Observability
RUNS_DIR=runs
LANGSMITH_ENABLED=false

# Warehouse (Postgres 16 + pgvector via docker-compose; unset = warehouse disabled)
# DATABASE_URL=postgresql+asyncpg://finresearch:finresearch@localhost:5433/finresearch

# Collector (in-process scheduled refresh of watched instruments; requires DATABASE_URL)
# COLLECTOR_ENABLED=true
# COLLECTOR_INTERVAL_HOURS=24
