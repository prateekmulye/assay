# LLM backbone — Ollama Cloud (OpenAI-compatible /v1)
OLLAMA_API_KEY=your-ollama-cloud-key-here
LLM_BASE_URL=https://ollama.com/v1

# Web research
FIRECRAWL_API_KEY=your-firecrawl-key-here

# Model tiers (override models.yaml if set)
QUICK_MODEL=gpt-oss:20b
DEEP_MODEL=gpt-oss:120b
# Sampling temperatures per tier (defaults: quick 0.3, deep 0.5)
# QUICK_TEMPERATURE=0.3
# DEEP_TEMPERATURE=0.5

# Debate
RESEARCH_DEBATE_ROUNDS=1
RISK_DEBATE_ROUNDS=1
DEBATE_MODE=on

# Memory (verdict cache lives in the warehouse; embeddings stay local)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Observability
RUNS_DIR=runs
# Root log level for the API process (default INFO)
# LOG_LEVEL=INFO

# Server
# Port uvicorn binds inside the container (docker/entrypoint.sh; default 7860)
# PORT=7860
# Comma-separated CORS origins (default * — tighten in production;
# docker-compose.prod.yml pins it to https://$CADDY_DOMAIN)
# ALLOWED_ORIGINS=https://finresearch.example.com
# Honor X-Forwarded-For for rate limiting/quotas — set ONLY behind a trusted
# proxy (the prod compose sets it for the Caddy edge)
# TRUST_PROXY=1
# Shared rate-limiter backend for multi-replica deploys (in-memory if unset)
# REDIS_URL=redis://localhost:6379/0

# Warehouse (Postgres 16 + pgvector via docker-compose; unset = warehouse disabled)
# DATABASE_URL=postgresql+asyncpg://finresearch:finresearch@localhost:5433/finresearch
# Echo SQL statements to the log (noisy; dev debugging only)
# DB_ECHO=true

# Collector (in-process scheduled refresh of watched instruments; requires DATABASE_URL)
# COLLECTOR_ENABLED=true
# COLLECTOR_INTERVAL_HOURS=24

# Demo guard (daily live-run caps on POST /api/analyze; requires DATABASE_URL)
# ADMIN_TOKEN=change-me            # X-Admin-Token header bypasses all rate/quota limits
# DEMO_RUNS_PER_IP_PER_DAY=3
# DEMO_RUNS_GLOBAL_PER_DAY=25

# Fake-LLM demo mode: deterministic offline LLM + canned tool data (no keys needed)
# APP_FAKE_LLM=1

# --- Production (docker-compose.prod.yml; see docs/deploy.md) ---------------
# Domain Caddy serves (auto-HTTPS via Let's Encrypt). Leave unset to test the
# prod stack locally on plain http://localhost (Caddyfile falls back to :80).
# CADDY_DOMAIN=finresearch.prateekmulye.dev
# Postgres password for the in-stack db service. REQUIRED by the prod compose
# (no default) — generate a strong one, e.g.: openssl rand -base64 24
# POSTGRES_PASSWORD=change-me-strong-random
